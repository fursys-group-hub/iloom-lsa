# Git에 올리면 안 되는 파일/폴더 목록. 비밀번호, 임시 빌드 파일, 개인정보 등을 보호한다.
node_modules
.next
.env.local
.env
.omc

# 노션 raw export (CSV/HTML 덤프) - 파싱해서 lessons-data.ts로 생성
프로젝트_기록/ExportBlock-*/
ExportBlock-*/
프로젝트_기록/*.xlsx

# 개인정보 보관 (학생 사진, 이력서 등 — 절대 커밋 금지)
_private/

# 교육생 개인 평가 데이터 (실명 포함)
scripts/memo-rewrites.json
scripts/practice-rewrites.json

# 교육 원본 자료 (대용량 PPTX/xlsx — 100MB 초과)
기존자료/

# textbook 파서 임시 출력
scripts/textbook/output/

# textbook 챕터 이미지 — Supabase Storage('textbook-images' bucket)로 호스팅됨
# 로컬 다운로드는 디버그용일 뿐, git/Railway에 올리지 않음
public/textbook-images/

# 안전망 — 혹시 모를 민감 파일 실수 방지
app/*.jpg
app/*.jpeg
app/*.png
app/*.pdf
**/이력서*.pdf
**/합격자*.pdf
